# Vulture Environment Configuration
# Copy this file to .env and fill in the required values:
#   cp .env.example .env
#
# Alternatively, use config.ini + gen-env.sh:
#   cp config.ini.example config.ini
#   make gen-env

# =============================================================================
# REQUIRED — docker-compose will refuse to start without these
# =============================================================================

# Database password (choose a strong password)
VULTURE_DB_PASSWORD=change-me-in-production

# JWT signing secret (generate with: openssl rand -hex 32)
VULTURE_JWT_SECRET=

# =============================================================================
# Application
# =============================================================================
VULTURE_APP_NAME=vulture

# Local mode (passwordless auth — set to true for development only)
VULTURE_LOCAL_MODE=false

# =============================================================================
# Ports
# =============================================================================
VULTURE_BACKEND_PORT=28080
VULTURE_AGENT_CHAOS_PORT=28001
VULTURE_AGENT_OWASP_PORT=28002
VULTURE_AGENT_SOC2_PORT=28003
VULTURE_AGENT_CWE_PORT=28004
VULTURE_AGENT_PROVE_PORT=28005
VULTURE_AGENT_XSS_PORT=28006
VULTURE_AGENT_SSDF_PORT=28007
VULTURE_AGENT_DISCOVER_PORT=28008
VULTURE_FRONTEND_INTERNAL=23000
VULTURE_FRONTEND_HOST=23001
VULTURE_POSTGRES_INTERNAL_PORT=25432
VULTURE_POSTGRES_HOST_PORT=25433

# =============================================================================
# Database
# =============================================================================
VULTURE_DB_NAME=vulture
VULTURE_DB_USER=vulture
VULTURE_DB_SQLITE_PATH=/data/vulture.db

# =============================================================================
# LLM Configuration (optional — skill-based audits work without LLM)
# =============================================================================

# Set to "true" to enable LLM-powered deep analysis after skill-based scanning
VULTURE_USE_LLM=false

# LLM model to use (supports OpenAI, Claude, Gemini, and local models via LiteLLM)
VULTURE_LLM_MODEL=gpt-4o

# Override context window size (auto-detected from model if unset)
# VULTURE_LLM_CTX_SIZE=

# --- Cooperative cancellation / runaway guards (feature 0061) ---------------
# Whole-audit wall-clock ceiling in seconds, shared across the skill, generate,
# and L5 phases. Backstops the disconnect fast-path so an audit can never run
# orphaned indefinitely. Must be >= the backend per-agent timeout (600s); 0
# disables (removes the hard guarantee — not recommended in prod).
# VULTURE_AGENT_MAX_AUDIT_SECONDS=900
# Per-LLM-call timeout (seconds); bounds each call so a hung/slow model cannot
# starve the cancel/deadline checks between batches.
# VULTURE_LLM_CALL_TIMEOUT_SEC=120
# Dedicated audit-producer thread pool size = per-agent concurrent-audit cap.
# VULTURE_AUDIT_EXECUTOR_WORKERS=8

# =============================================================================
# LLM Provider Keys (set the one matching your chosen model)
# =============================================================================

# OpenAI / OpenAI-compatible (LM Studio, vLLM, Ollama OpenAI mode)
OPENAI_API_KEY=
# OPENAI_BASE_URL=http://localhost:1234/v1

# Anthropic Claude
# ANTHROPIC_API_KEY=

# Google Gemini
# GEMINI_API_KEY=

# Ollama (local models)
# OLLAMA_API_BASE=http://localhost:11434

# =============================================================================
# Embedding (for memory/similarity search)
# =============================================================================
VULTURE_EMBEDDING_MODEL=text-embedding-3-small
# VULTURE_EMBEDDING_URL=

# =============================================================================
# Source directory mount (for docker-compose volume binding)
# =============================================================================
# VULTURE_SOURCE_DIR=./
