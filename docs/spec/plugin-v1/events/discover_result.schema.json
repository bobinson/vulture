{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/bobinson/vulture/main/docs/spec/plugin-v1/events/discover_result.schema.json",
  "title": "discover_result event payload",
  "type": "object",
  "required": ["target_url"],
  "additionalProperties": true,
  "properties": {
    "target_url": {"type": "string", "format": "uri"},
    "url_count": {"type": "integer", "minimum": 0},
    "api_count": {"type": "integer", "minimum": 0},
    "form_count": {"type": "integer", "minimum": 0},
    "technologies": {
      "type": "array",
      "items": {"type": "string"}
    },
    "site_map_json": {
      "type": "object",
      "description": "Tech-stack-specific site map. Orchestrator merges across plugins by URL."
    },
    "learnings_context": {"type": "string", "maxLength": 8192}
  }
}
